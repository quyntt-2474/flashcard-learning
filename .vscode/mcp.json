{
  "servers": {
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "type": "http",
      "headers": {
        "Authorization": "Bearer ${input:githubToken}"
      }
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "NOTION_TOKEN": "${env:DEMO_NOTION_TOKEN}"
        // Set xong cần restart VSCode để nó pick up env variable này, hoặc có thể dùng input để prompt token lên mỗi lần start server như figma bên dưới
      },
      "type": "stdio"
    },
    "figma": {
      "command": "npx",
      "args": [
        "-y",
        "figma-developer-mcp",
        "--figma-api-key=${input:figmaToken}",
        "--stdio"
      ],
      "type": "stdio"
    }
  },
  "inputs": [
    {
      "id": "notionToken",
      "type": "promptString",
      "description": "Notion API Token",
      "password": true
    },
    {
      "id": "figmaToken",
      "type": "promptString",
      "description": "Figma API Token (DEMO_FIGMA_TOKEN)",
      "password": true
    },
    {
      "id": "githubToken",
      "type": "promptString",
      "description": "GitHub Personal Access Token (repo scope)",
      "password": true
    }
  ]
}
